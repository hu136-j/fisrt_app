{
  "name": "desktop-time-tracker",
  "version": "1.0.0",
  "description": "Windows离线桌面时间记录APP - 纯本地、无联网、轻量级时间管理工具",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package": "electron-builder --win portable"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.desktop.timetracker",
    "productName": "桌面时间记录",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico"
    },
    "portable": {
      "artifactName": "TimeTracker.exe"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "style.css",
      "app.js"
    ]
  }
}
